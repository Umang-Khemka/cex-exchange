generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────
model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())

  orders   Order[]
  fills    Fill[]
  balances Balance[]
  payments Payment[]
}

// ─────────────────────────────────────────
// MARKETS  e.g. SOL/USD, BTC/USD
// ─────────────────────────────────────────
model Market {
  id         Int      @id @default(autoincrement())
  name       String                    // "Solana"
  symbol     String   @unique          // "sol"
  baseAsset  String                    // "SOL"
  quoteAsset String   @default("USD")
  createdAt  DateTime @default(now())

  orders  Order[]
  candles Candle[]
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────
model Order {
  id        Int         @id
  userId    Int
  marketId  Int
  market    String
  price     Decimal     @db.Decimal(20, 8)
  qty       Decimal     @db.Decimal(20, 8)
  filledQty Decimal     @db.Decimal(20, 8) @default(0)
  type      OrderType
  side      OrderSide
  status    OrderStatus @default(OPEN)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user       User   @relation(fields: [userId],   references: [id])
  marketRel  Market @relation(fields: [marketId], references: [id])
  fills      Fill[]

  @@index([userId])
  @@index([market, status])
  @@index([createdAt])
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  FILLED
  CANCELLED
  PARTIALLY_FILLED
}

// ─────────────────────────────────────────
// FILLS — every matched trade
// ─────────────────────────────────────────
model Fill {
  id              Int       @id @default(autoincrement())
  qty             Decimal   @db.Decimal(20, 8)
  price           Decimal   @db.Decimal(20, 8)
  side            OrderSide
  fillType        FillType
  userId          Int
  asset           String
  originalOrderId Int
  fee             Decimal   @db.Decimal(20,8) @default(0)
  feeAssest       String    @default("USD")
  createdAt       DateTime  @default(now())

  user  User  @relation(fields: [userId],          references: [id])
  order Order @relation(fields: [originalOrderId], references: [id])

  @@index([userId])
  @@index([originalOrderId])
  @@index([asset, createdAt])
}

model FeeCollection {
  id        Int      @id @default(autoincrement())
  asset     String
  amount    Decimal  @db.Decimal(20, 8)
  fillType  FillType // MAKER | TAKER
  userId    Int
  createdAt DateTime @default(now())

  @@index([asset])
  @@index([createdAt])
}

enum FillType {
  MAKER
  TAKER
}

// ─────────────────────────────────────────
// BALANCES
// ─────────────────────────────────────────
model Balance {
  id        Int      @id @default(autoincrement())
  userId    Int
  asset     String   // "USD" | "SOL" | "BTC"
  available Decimal  @db.Decimal(20, 8) @default(0)
  locked    Decimal  @db.Decimal(20, 8) @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, asset])
  @@index([userId])
}

// ─────────────────────────────────────────
// CANDLES — OHLCV for chart
// ─────────────────────────────────────────
model Candle {
  id        Int            @id @default(autoincrement())
  marketId  Int
  market    String
  interval  CandleInterval
  open      Decimal        @db.Decimal(20, 8)
  high      Decimal        @db.Decimal(20, 8)
  low       Decimal        @db.Decimal(20, 8)
  close     Decimal        @db.Decimal(20, 8)
  volume    Decimal        @db.Decimal(20, 8)
  timestamp DateTime

  marketRel Market @relation(fields: [marketId], references: [id])

  @@unique([market, interval, timestamp])
  @@index([market, interval, timestamp])
}

enum CandleInterval {
  ONE_MINUTE
  FIVE_MINUTES
  FIFTEEN_MINUTES
  ONE_HOUR
  FOUR_HOURS
  ONE_DAY
}

model Payment {
  id                Int           @id @default(autoincrement())
  userId            Int
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  amount            Decimal       @db.Decimal(20, 8)
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  asset             String        @default("USD")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}